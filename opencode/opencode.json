{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": [
    ".opencode/instructions/communication.md",
    ".opencode/instructions/coding-policy.md",
    ".opencode/memory/index.md"
  ],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/id_rsa": "deny",
      "**/id_dsa": "deny",
      "**/id_ecdsa": "deny",
      "**/id_ed25519": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.netrc": "deny",
      "**/secrets/**": "deny",
      "**/.secrets/**": "deny"
    },
    "grep": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/id_rsa": "deny",
      "**/id_dsa": "deny",
      "**/id_ecdsa": "deny",
      "**/id_ed25519": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.netrc": "deny",
      "**/secrets/**": "deny",
      "**/.secrets/**": "deny"
    },
    "edit": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/*.env": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "**/id_rsa": "deny",
      "**/id_dsa": "deny",
      "**/id_ecdsa": "deny",
      "**/id_ed25519": "deny",
      "**/.npmrc": "deny",
      "**/.pypirc": "deny",
      "**/.netrc": "deny",
      "**/secrets/**": "deny",
      "**/.secrets/**": "deny"
    },
    "bash": {
      "*": "allow",
      "rm *": "ask",
      "rm -rf *": "ask",
      "mv *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "git reset *": "ask",
      "git clean *": "ask",
      "git checkout -- *": "ask",
      "git restore *": "ask",
      "git rebase *": "ask",
      "git push --force*": "ask",
      "sudo *": "ask",
      "sh -c *": "ask",
      "bash -c *": "ask",
      "zsh -c *": "ask",
      "cat *env*": "deny",
      "less *env*": "deny",
      "more *env*": "deny",
      "open *env*": "deny",
      "printenv*": "deny",
      "env": "deny"
    },
    "external_directory": {
      "*": "allow",
      "../**": "deny",
      "/**": "deny",
      "~/**": "deny"
    }
  }
}
